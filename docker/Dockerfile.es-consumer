FROM golang:1.21-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /es-consumer ./cmd/es-consumer

FROM alpine:3.19

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /es-consumer /usr/local/bin/es-consumer

EXPOSE 8086

HEALTHCHECK --interval=30s --timeout=3s --start-period=15s --retries=3 \
  CMD wget -qO- http://localhost:8086/health || exit 1

ENTRYPOINT ["es-consumer"]
