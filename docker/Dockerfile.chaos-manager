FROM golang:1.21-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download 2>/dev/null || true

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags="-s -w" \
    -o /chaos-manager \
    ./cmd/chaos-manager

FROM alpine:3.19

RUN apk add --no-cache ca-certificates wget

WORKDIR /app

COPY --from=builder /chaos-manager /usr/local/bin/chaos-manager

ENV CHAOS_MANAGER_PORT=8088

EXPOSE 8088

CMD ["chaos-manager"]
